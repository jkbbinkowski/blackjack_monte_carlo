cat(sprintf("CVaR (Expected Shortfall, 95%%): %.2f jednostek\n", mc_results$CVaR))
library(dplyr)
library(ggplot2)
library(moments)
# Jeśli nie masz randtests, odkomentuj poniższą linijkę:
# install.packages("randtests")
library(randtests)
# Wczytanie danych
dane <- read.csv("/Users/jakubbinkowski/dev_repo/blackjack_monte_carlo/results/results_20260512_013729.csv", sep=";")
# 1. LIKWIDACJA PODWÓJNEGO KSIĘGOWANIA I WYLICZENIE ZYSKU
dane_zsumowane <- dane %>%
mutate(
# Zabezpieczenie przed różnym formatowaniem prawdy przez Pythona w CSV
is_double = as.character(double_down_bet) %in% c("True", "TRUE", "true", "1", TRUE),
# Wyciągamy zakład bazowy: jeśli to double, dzielimy wartość z CSV przez 2
base_bet = ifelse(is_double, as.numeric(bet) / 2, as.numeric(bet)),
# Prawdziwy pieniądz na stole:
zysk_kwotowy = as.numeric(round_result_stat) * base_bet
) %>%
group_by(round, player_idx) %>%
summarise(
calkowity_wynik_jednostkowy = sum(as.numeric(round_result_stat), na.rm = TRUE),
prawdziwy_zysk = sum(zysk_kwotowy, na.rm = TRUE),
true_count = first(true_count),
.groups = 'drop'
)
