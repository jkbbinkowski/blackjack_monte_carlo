library(dplyr)
library(ggplot2)
statystyki_kelly_zbinowane <- dane_zsumowane %>%
mutate(tc_kategoria = case_when(
true_count <= -5 ~ "<= -5 TC",
true_count > -5 & true_count <= -2 ~ "-4 do -2 TC",
true_count > -2 & true_count <= 0 ~ "-1 do 0 TC",
true_count > 0 & true_count <= 2 ~ "+1 do +2 TC",
true_count > 2 & true_count <= 5 ~ "+3 do +5 TC",
true_count > 5 ~ "> +5 TC"
)) %>%
mutate(tc_kategoria = factor(tc_kategoria, levels = c(
"<= -5 TC",
"-4 do -2 TC",
"-1 do 0 TC",
"+1 do +2 TC",
"+3 do +5 TC",
"> +5 TC"
))) %>%
group_by(tc_kategoria) %>%
summarise(
n_rozdan = n(),
ev = mean(calkowity_wynik, na.rm = TRUE),
wariancja = var(calkowity_wynik, na.rm = TRUE),
kelly_fraction = ev / wariancja,
.groups = 'drop'
) %>%
filter(n_rozdan > 100)
print(statystyki_kelly_zbinowane)
# Robimy nowy, wygładzony wykres "Bestii"
ggplot(statystyki_kelly_zbinowane, aes(x = tc_kategoria, y = wariancja, group = 1)) +
geom_line(color = "steelblue", size = 1.5) +
geom_point(size = 4, color = "darkred") +
labs(
title = "Wariancja vs Pogrupowany True Count",
subtitle = "Po wyeliminowaniu szumu losowego",
x = "Kategoria True Count",
y = "Wariancja (sigma^2)"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
