subtitle = "Po wyeliminowaniu szumu losowego",
x = "Kategoria True Count",
y = "Wariancja (sigma^2)"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
library(dplyr)
# --- DODATKOWE FUNKCJE DO ANALIZY RYZYKA ---
# ROR
calculate_ror <- function(u, sigma_sq, B) {
if (u <= 0) {
return(1.0)
}
ror <- exp((-2 * u * B) / sigma_sq)
return(min(ror, 1.0))
}
# Sharpe
calculate_sharpe <- function(u, sigma) {
rf <- 0
if (sigma == 0) return(NA)
return((u - rf) / sigma)
}
# VAR analityczny
calculate_var_analytical <- function(u, sigma, n_hands, alpha = 0.05) {
k <- qnorm(1 - alpha)
var_value <- (k * sigma * sqrt(n_hands) - u * n_hands)
return(var_value)
}
# VAR Monte Carlo
calculate_var_mc <- function(dane_surowe, dlugosc_sesji = 100, alpha = 0.05) {
wyniki_sesji <- dane_surowe %>%
mutate(session_id = (row_number() - 1) %/% dlugosc_sesji + 1) %>%
group_by(session_id) %>%
summarise(
wynik_sesji = sum(round_result_stat, na.rm = TRUE),
liczba_rozdan = n(),
.groups = 'drop'
) %>%
filter(liczba_rozdan == dlugosc_sesji)
var_mc <- quantile(wyniki_sesji$wynik_sesji, probs = alpha, na.rm = TRUE)
cvar_mc <- mean(wyniki_sesji$wynik_sesji[wyniki_sesji$wynik_sesji <= var_mc], na.rm = TRUE)
return(list(VaR = as.numeric(var_mc), CVaR = cvar_mc))
}
# --- OBLICZENIA GŁÓWNE ---
u_global <- mean(dane$round_result_stat, na.rm = TRUE)
sigma_global <- sd(dane$round_result_stat, na.rm = TRUE)
sigma_sq_global <- var(dane$round_result_stat, na.rm = TRUE)
kapital_poczatkowy <- 20000000
dlugosc_sesji <- 100
cat("\n--- RESULTS ---\n")
# RoR
ror_wynik <- calculate_ror(u_global, sigma_sq_global, kapital_poczatkowy)
cat(sprintf("Risk of Ruin (RoR): %.2f%%\n", ror_wynik * 100))
# Sharpe
sharpe_wynik <- calculate_sharpe(u_global, sigma_global)
cat(sprintf("Wskaźnik Sharpe'a (dla pojedynczego rozdania): %.5f\n", sharpe_wynik))
# VaR Analityczny
var_analit <- calculate_var_analytical(u_global, sigma_global, dlugosc_sesji)
cat(sprintf("VaR (Analityczny, 95%%) dla %d rozdań: %.2f jednostek\n", dlugosc_sesji, var_analit))
# VaR Monte Carlo (wreszcie działający)
mc_results <- calculate_var_mc(dane, dlugosc_sesji = dlugosc_sesji)
cat(sprintf("VaR (Monte Carlo, 95%%) dla sesji %d rozdań: %.2f jednostek\n", dlugosc_sesji, mc_results$VaR))
cat(sprintf("CVaR (Expected Shortfall, 95%%): %.2f jednostek\n", mc_results$CVaR))
library(dplyr)
dane <- read.csv("/Users/jakubbinkowski/dev_repo/blackjack_monte_carlo/results/results_20260512_012504.csv", sep=";")
dane_zsumowane <- dane %>%
group_by(round, player_idx) %>%
summarise(calkowity_wynik = sum(round_result_stat), true_count = first(true_count), .groups = 'drop')
plot(density(dane_zsumowane$calkowity_wynik))
mu <- mean(dane_zsumowane$calkowity_wynik, na.rm = TRUE)
sigma <- sd(dane_zsumowane$calkowity_wynik, na.rm = TRUE)
cat("EV: ", mu, "\n")
cat("Std dev: ", sigma, "\n")
curve(dnorm(x, mean = mu, sd = sigma),
add = TRUE,
col = "darkgreen",
lwd = 3)
